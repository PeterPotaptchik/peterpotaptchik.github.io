<div class="news">
  {% if site.news != blank %}
    {% assign years = site.news | group_by: "year" | sort: "name" | reverse %}

    {% assign shown = 0 %}
    {% if include.limit and site.announcements.limit %}
      {% assign news_limit = site.announcements.limit %}
    {% else %}
      {% assign news_limit = site.news.size %}
    {% endif %}

    {% for year_group in years %}
      {% assign items = year_group.items | sort: "order" %}
      {% assign group_count = items | size %}

      <div class="news-year-group">
        <div class="news-year">{{ year_group.name }}</div>
        <div class="news-items">
          {% for item in items %}
            {% if shown < news_limit %}
              <div class="news-item">
                {% if item.inline %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              </div>
              {% assign shown = shown | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
